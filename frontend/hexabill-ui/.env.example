# API base URL (used by apiConfig.js). No trailing slash; /api is appended if missing.
# - Not set + app opened from localhost → uses http://localhost:5000/api (backend must be running).
# - Not set + app opened from production (e.g. Vercel) → uses https://hexabill.onrender.com/api.
# - For Vercel: set in Project Settings → Environment Variables: VITE_API_BASE_URL=https://hexabill.onrender.com
# - For local dev: http://localhost:5000 or http://localhost:5000/api
VITE_API_BASE_URL=http://localhost:5000/api

# --- AI / LLM keys (optional - for smart CSV mapping, insights, etc.) ---
# Copy this file to .env and fill in your keys. Never commit .env.
# Groq (free tier): https://console.groq.com/
VITE_GROQ_API_KEY=
# Google Gemini: https://aistudio.google.com/apikey
VITE_GEMINI_API_KEY=
# HuggingFace: https://huggingface.co/settings/tokens
VITE_HUGGINGFACE_TOKEN=
